import std::mask;
import std::color;
import std::core;
import std::effects;
import std::vision;
import std::advanced;


frame = load("input_image.jpg");
edited_frame = frame -> cyanotype()
                     -> cinematic()
                     -> threshold(120)
                     -> hdr2(1.15)
                     -> soft_blur(25);

export(edited_frame, "Outputs/output.png");
print("The Code was executed Successfully");