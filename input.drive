import std::core;
import std::color;
import std::advanced;

audio = track("test_inputs/input_song.mp3");

af gain(db) {
    l = l*db;
    r = l*db;
}

af tremolo(freq, depth) {

    let mod = 1.0 - depth + depth * sin(time * 6.283185 * freq);

    l = l * mod;
    r = r * mod;

}

audio = audio -> tremolo(5,0.8);

export(audio, "Outputs/output.wav");
